# Pick one provider — set its key and (optionally) point SWITCHBACK_MODEL at it.
# The default model is claude-opus-4-7 (needs ANTHROPIC_API_KEY).
#
# Plan generation goes through LiteLLM, so any model string LiteLLM understands
# works. See https://docs.litellm.ai/docs/providers for the full list.

# --- Claude (default) -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Cheaper alternatives (uncomment one + set SWITCHBACK_MODEL) ------------
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

# --- Model selection --------------------------------------------------------
# SWITCHBACK_MODEL=claude-opus-4-7            # default, highest quality
# SWITCHBACK_MODEL=claude-sonnet-4-6          # cheaper Claude
# SWITCHBACK_MODEL=openai/gpt-4o-mini         # cheap OpenAI
# SWITCHBACK_MODEL=deepseek/deepseek-chat     # very cheap
# SWITCHBACK_MODEL=gemini/gemini-2.0-flash-exp
# SWITCHBACK_MODEL=groq/llama-3.3-70b-versatile
# SWITCHBACK_MODEL=openrouter/anthropic/claude-3.5-sonnet
